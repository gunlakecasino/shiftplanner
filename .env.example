# ── Build-time (Railway Docker build args / local `pnpm build`) ──
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# ── Runtime only (Railway service variables — never NEXT_PUBLIC_) ──
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# REQUIRED in production (Railway). Session cookie HMAC signing only.
# Generate e.g. `openssl rand -base64 48`. Set BEFORE deploying fail-closed builds.
# Production refuses service-role fallback — missing secret → PIN login 503 / session routes 401.
OPS_SESSION_SECRET=generate_a_long_random_secret_at_least_32_chars
XAI_API_KEY=your_xai_key

# Optional: one-release dual-verify while rotating off an old secret (e.g. prior
# service-role-as-session-secret material). Sign uses OPS_SESSION_SECRET only;
# verify accepts primary OR PREV. Remove PREV after soak. Server-only — never NEXT_PUBLIC_.
# OPS_SESSION_SECRET_PREV=

# Optional session tuning
# OPS_SESSION_IDLE_MINUTES=30
# OPS_SESSION_ABSOLUTE_HOURS=18

# Dev only (do NOT set in production — never expose service role to the client)
# NEXT_PUBLIC_SUPABASE_SERVICE_ROLE_KEY=dev_convenience_only
