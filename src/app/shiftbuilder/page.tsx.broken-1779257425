// ============================================================================
// Types — Clean, narrow, carry-forward the good model from prior work
// ============================================================================

type AssignmentSource = "engine" | "manual" | null;

interface ShiftAssignment {
  slotKey: string;
  tmId?: string;
  tmName?: string;
  source: AssignmentSource;
  isLocked: boolean;
  type: "zone" | "rr" | "aux" | "break" | "overlap";
  sub?: "mens" | "womens";
  breakGroup?: 1 | 2 | 3;   // Break rotation group for this person
}

interface NightPlan {
  nightDate: string;
  currentPageType: "deployment" | "breaks" | "overlaps";
  assignments: Record<string, ShiftAssignment>;
}

interface WeekPlan {
  weekStart: string;
  nights: NightPlan[];
}

