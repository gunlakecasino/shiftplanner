// ============================================================================
// UI Key <-> Real DB Slot mapping (so the gorgeous print-accurate shell stays intact)
// ============================================================================

interface DbSlotInfo {
  slotKey: string;
  slotType: "zone" | "rr" | "aux";
  rrSide?: "mens" | "womens" | null;
}

const UI_DB_MAP: Record<string, DbSlotInfo> = {
  // Zones
  Z1: { slotKey: "zone_1", slotType: "zone" },
  Z2: { slotKey: "zone_2", slotType: "zone" },
  Z3: { slotKey: "zone_3", slotType: "zone" },
  Z4: { slotKey: "zone_4", slotType: "zone" },
  Z5: { slotKey: "zone_5", slotType: "zone" },
  Z6: { slotKey: "zone_6", slotType: "zone" },
  Z7: { slotKey: "zone_7", slotType: "zone" },
  Z8: { slotKey: "zone_8", slotType: "zone" },
  Z9: { slotKey: "zone_9", slotType: "zone" },
  Z10: { slotKey: "zone_10", slotType: "zone" },
  // RR (map UI 1 -> real rr_1_2, 2->rr_6 etc.)
  MRR1: { slotKey: "rr_1_2", slotType: "rr", rrSide: "mens" },
  WRR1: { slotKey: "rr_1_2", slotType: "rr", rrSide: "womens" },
  MRR2: { slotKey: "rr_6", slotType: "rr", rrSide: "mens" },
  WRR2: { slotKey: "rr_6", slotType: "rr", rrSide: "womens" },
  MRR3: { slotKey: "rr_7", slotType: "rr", rrSide: "mens" },
  WRR3: { slotKey: "rr_7", slotType: "rr", rrSide: "womens" },
  MRR4: { slotKey: "rr_8", slotType: "rr", rrSide: "mens" },
  WRR4: { slotKey: "rr_8", slotType: "rr", rrSide: "womens" },
  MRR5: { slotKey: "rr_10", slotType: "rr", rrSide: "mens" },
  WRR5: { slotKey: "rr_10", slotType: "rr", rrSide: "womens" },
  // Aux (best effort match to real common keys)
  "AUX-Z9SR": { slotKey: "z9_sr", slotType: "aux" },
  "AUX-ADMIN": { slotKey: "admin", slotType: "aux" },
  "AUX-TRASH1": { slotKey: "trash_1", slotType: "aux" },
  "AUX-TRASH2": { slotKey: "trash_2", slotType: "aux" },
  "AUX-SUP": { slotKey: "support_1", slotType: "aux" },
};

function uiKeyToDb(uiKey: string): DbSlotInfo | null {
  return UI_DB_MAP[uiKey] || null;
}

function dbToUiKey(dbSlot: { slotKey: string; rrSide?: string | null }): string | null {
  // Reverse lookup (first match wins for simplicity)
  for (const [ui, info] of Object.entries(UI_DB_MAP)) {
    if (
      info.slotKey === dbSlot.slotKey &&
      (info.rrSide || null) === (dbSlot.rrSide || null)
    ) {
      return ui;
    }
  }
  return null;
}

// ============================================================================
// Main Component
// ============================================================================

export default function ShiftBuilderPage() {
  // For now we work with a single night (deployment view) — easily extensible to full WeekPlan
  // Real data state (Supabase backed)
  const [currentNight, setCurrentNight] = useState<NightInfo | null>(null);
  const [realRoster, setRealRoster] = useState<(TeamMember & { isOnSchedule: boolean })[]>([]);
  const [availableNights, setAvailableNights] = useState<NightInfo[]>([]);
  const [isLoadingData, setIsLoadingData] = useState(true);
  const [lastSync, setLastSync] = useState<string>("");

  // Internal plan still drives the beautiful UI shell (keys = UI keys like Z1, MRR1, AUX-ADMIN)
  // We translate to/from real DB slot keys on load & write.
  const [plan, setPlan] = useState<NightPlan>({
    nightDate: "2026-05-21",
    currentPageType: "deployment",
    assignments: {},
  });

  const [selectedRosterId, setSelectedRosterId] = useState<string | null>(null);

  // Break Group selector (grey squares in header) — selectable 1/2/3, defaults to Golden standard
  const [breakGroup, setBreakGroup] = useState<1 | 2 | 3>(2);

  // Quick Action Wheel for a specific slot
  const [quickActionFor, setQuickActionFor] = useState<string | null>(null);
  const [quickLookPosition, setQuickLookPosition] = useState(null);
  const artboardRef = useRef<HTMLDivElement>(null);
  const positioningRef = useRef<HTMLDivElement>(null); // host for the contextual fan overlay (correct coordinate frame)

  // For custom break group dropdowns (better UX than native select)
  const [openBreakMenuFor, setOpenBreakMenuFor] = useState<string | null>(null);

  // Contextual fan menu states
  const [breakFanOpenFor, setBreakFanOpenFor] = useState(null);
  const [fanHoveredItem, setFanHoveredItem] = useState(null);
  const [fanHoverTimer, setFanHoverTimer] = useState(null);

  // ============================================================================
  // New UX: Week Strip + View Tabs (Deployment vs Breaks & Overlaps)
  // ============================================================================
  const [selectedDayIndex, setSelectedDayIndex] = useState(0); // 0 = Friday ... 6 = Thursday
  const [currentView, setCurrentView] = useState<"deployment" | "breaks">("deployment");

  const selectedDay = DAY_DEFS[selectedDayIndex];

  // Derived: current assignments map
  const assignments = plan.assignments;

  // ==========================================================================
  // Real persistence helpers (map UI <-> DB then call data layer)
  // ==========================================================================

  const persistAssign = async (uiKey: string, tm: { id: string; name: string }) => {
    const dbInfo = uiKeyToDb(uiKey);
    if (!currentNight || !dbInfo) {
      console.warn("[shiftbuilder] No night or mapping for", uiKey);
      return;
    }
    try {
      await upsertZoneAssignment({
        nightId: currentNight.id,
        slotKey: dbInfo.slotKey,
        tmId: tm.id,
        slotType: dbInfo.slotType,
        rrSide: dbInfo.rrSide ?? null,
        isLocked: assignments[uiKey]?.isLocked ?? false,
      });
      setLastSync(new Date().toLocaleTimeString());
    } catch (e: any) {
      console.error("[shiftbuilder] persistAssign failed", e);
      alert("Failed to save assignment to Supabase: " + e.message);
      // caller will have optimistically updated; in real app we would rollback here
    }
  };

  const persistUnassign = async (uiKey: string) => {
    const dbInfo = uiKeyToDb(uiKey);
    if (!currentNight || !dbInfo) return;
    try {
      await upsertZoneAssignment({
        nightId: currentNight.id,
        slotKey: dbInfo.slotKey,
        tmId: null,
        slotType: dbInfo.slotType,
        rrSide: dbInfo.rrSide ?? null,
      });
      setLastSync(new Date().toLocaleTimeString());
    } catch (e: any) {
      console.error("[shiftbuilder] persistUnassign failed", e);
      alert("Failed to clear assignment in Supabase: " + e.message);
    }
  };

  const persistToggleLock = async (uiKey: string) => {
    const dbInfo = uiKeyToDb(uiKey);
    const current = assignments[uiKey];
    if (!currentNight || !dbInfo || !current) return;
    try {
      await toggleAssignmentLock({
        nightId: currentNight.id,
        slotKey: dbInfo.slotKey,
        slotType: dbInfo.slotType,
        rrSide: dbInfo.rrSide ?? null,
        currentLocked: current.isLocked,
      });
      setLastSync(new Date().toLocaleTimeString());
    } catch (e: any) {
      console.error("[shiftbuilder] persistToggleLock failed", e);
      alert("Failed to toggle lock in Supabase: " + e.message);
    }
  };

  // ==========================================================================
  // Load real night data (assignments + roster with on-schedule)
  // ==========================================================================

  const loadNight = useCallback(async (night: NightInfo) => {
    setIsLoadingData(true);
    try {
      const [assignmentsRows, rosterWithSchedule] = await Promise.all([
        getNightAssignments(night.id),
        getTeamMembersForNight(night.id),
      ]);

      // Translate real DB rows → internal UI-keyed assignments for the shell
      const newAssignments: Record<string, ShiftAssignment> = {};
      for (const row of assignmentsRows) {
        const uiKey = dbToUiKey({ slotKey: row.slotKey, rrSide: row.rrSide });
        if (uiKey) {
          newAssignments[uiKey] = {
            slotKey: uiKey,
            tmId: row.tmId || undefined,
            tmName: row.tmName,
            source: "manual", // or "imported" if we track source later
            isLocked: row.isLocked,
            type: (row.slotType as any) || "zone",
            sub: row.rrSide || undefined,
          };
        }
      }

      setPlan((prev) => ({
        ...prev,
        nightDate: night.nightDate,
        assignments: newAssignments,
      }));
      setRealRoster(rosterWithSchedule);
      setCurrentNight(night);
      setLastSync(new Date().toLocaleTimeString());
      // eslint-disable-next-line no-console
      console.log(`[shiftbuilder] Loaded night ${night.nightDate} (${night.id}) — ${assignmentsRows.length} slots`);
    } catch (e: any) {
      console.error("[shiftbuilder] loadNight failed", e);
      alert("Failed to load real data from Supabase. Check console + env keys.");
    } finally {
      setIsLoadingData(false);
    }
  }, []);

  // Initial load: pick a sensible default night with real data (2026-05-21 works well)
  useEffect(() => {
    (async () => {
      try {
        const nights = await listRecentNights(10);
        setAvailableNights(nights);
        // Prefer a night around 2026-05-21 or the first one that exists
        let target = nights.find((n) => n.nightDate === "2026-05-21") || nights[0];
        if (target) {
          await loadNight(target);
        } else {
          // Fallback: just load roster
          const roster = await getActiveTeamMembers();
          setRealRoster(roster.map((t) => ({ ...t, isOnSchedule: true })));
          setIsLoadingData(false);
        }
      } catch (e) {
        console.error("[shiftbuilder] initial load error", e);
        setIsLoadingData(false);
      }
    })();
    // eslint-disable-next-line react-hooks/exhaustive-deps
  }, []);

  // Live Supabase Realtime sync — reloads assignments on any external change for the night
  useEffect(() => {
    if (!currentNight?.id) return undefined;

    const channel = createNightAssignmentChannel(currentNight.id, () => {
      // eslint-disable-next-line no-console
      console.log("[shiftbuilder] realtime update detected — refreshing night data");
      loadNight(currentNight);
    });

    return () => {
      unsubscribeChannel(channel);
    };
  }, [currentNight, loadNight]);

  // ==========================================================================
  // Actions (local optimistic + real persistence)
  // ==========================================================================

  const assignTM = (slotKey: string, tm: { id: string; name: string }) => {
    // Optimistic UI update first (instant feel)
    setPlan((prev) => ({
      ...prev,
      assignments: {
        ...prev.assignments,
        [slotKey]: {
          slotKey,
          tmId: tm.id,
          tmName: tm.name,
          source: "manual",
          isLocked: prev.assignments[slotKey]?.isLocked ?? false,
          type: prev.assignments[slotKey]?.type ?? "zone",
          sub: prev.assignments[slotKey]?.sub,
          breakGroup: prev.assignments[slotKey]?.breakGroup ?? 1, // default to group 1
        },
      },
    }));
    // Persist immediately
    persistAssign(slotKey, tm);
  };

  const setBreakGroupForSlot = (slotKey: string, group: 1 | 2 | 3) => {
    setPlan((prev) => {
      const current = prev.assignments[slotKey];
      if (!current) return prev;
      return {
        ...prev,
        assignments: {
          ...prev.assignments,
          [slotKey]: {
            ...current,
            breakGroup: group,
          },
        },
      };
    });
    setOpenBreakMenuFor(null);
  };

  // Reusable nice Break Group pill — now with clean menu (no overflow)
  const BreakGroupPill = ({ slotKey, currentGroup }: { slotKey: string; currentGroup?: 1 | 2 | 3 }) => {
    const group = currentGroup ?? 1;
    const shades = {
      1: { bg: '#E5E7EB', text: '#374151' },
      2: { bg: '#9CA3AF', text: '#1F2937' },
      3: { bg: '#6B7280', text: '#FFFFFF' },
    };
    const shade = shades[group];
    const isOpen = openBreakMenuFor === slotKey;

    return (
      <div className="inline-block" data-break-group-pill>
        <div
          onClick={(e) => {
            e.stopPropagation();
            setOpenBreakMenuFor(isOpen ? null : slotKey);
          }}
          className="w-[17px] h-[17px] flex items-center justify-center text-[9px] font-bold rounded-[4px] cursor-pointer border border-[#C8C8CC] active:scale-95 transition"
          style={{ background: shade.bg, color: shade.text, fontFamily: 'var(--font-atkinson)' }}
          title="Change Break Group"
        >
          {group}
        </div>

        {isOpen && createPortal(
          <div
            className="fixed z-[200] bg-white border border-[#E5E5E7] rounded-xl shadow-2xl p-1 w-[52px]"
            style={{ top: 'auto', left: 'auto' }} // TODO: better positioning with ref
            onClick={(e) => e.stopPropagation()}
          >
            {[1,2,3].map(g => (
              <button
                key={g}
                onClick={() => setBreakGroupForSlot(slotKey, g as 1|2|3)}
                className={`w-full text-center py-1.5 text-xs rounded-lg ${group === g ? 'bg-[#F3F4F6] font-semibold' : 'hover:bg-[#FAFAFA]'}`}
              >
                Group {g}
              </button>
            ))}
          </div>,
          document.body
        )}
      </div>
    );
  };

  const unassign = (slotKey: string) => {
    setPlan((prev) => {
      const next = { ...prev.assignments };
      if (next[slotKey]) {
        next[slotKey] = {
          ...next[slotKey],
          tmId: undefined,
          tmName: undefined,
          source: null,
          // keep breakGroup so it remembers preference when re-assigned
        };
      }
      return { ...prev, assignments: next };
    });
    persistUnassign(slotKey);
  };

  const toggleLock = (slotKey: string) => {
    // Toggle locally first
    setPlan((prev) => {
      const current = prev.assignments[slotKey];
      if (!current) return prev;

      return {
        ...prev,
        assignments: {
          ...prev.assignments,
          [slotKey]: {
            ...current,
            isLocked: !current.isLocked,
          },
        },
      };
    });
    // Persist the lock flip
    persistToggleLock(slotKey);
  };

  // ==========================================================================
  // Drag & Drop (native + high quality feedback)
  // ==========================================================================

  const handleDragStart = (e: React.DragEvent, tmId: string, tmName: string) => {
    e.dataTransfer.setData("text/plain", JSON.stringify({ tmId, tmName }));
    e.dataTransfer.effectAllowed = "move";
  };

  const handleDragOver = (e: React.DragEvent) => {
    e.preventDefault();
    e.dataTransfer.dropEffect = "move";
  };

  const handleDrop = (e: React.DragEvent, slotKey: string) => {
    e.preventDefault();
    const data = e.dataTransfer.getData("text/plain");
    if (!data) return;

    try {
      const { tmId, tmName } = JSON.parse(data);
      assignTM(slotKey, { id: tmId, name: tmName });
    } catch {
      // ignore malformed drops
    }
  };

  const handleDragLeave = (e: React.DragEvent) => {
    // visual cleanup if needed
  };

  // Quick-assign for development / iPad testing (tap to assign next available)
  const quickAssign = (slotKey: string) => {
    const available = realRoster.find(
      (tm) => !Object.values(assignments).some((a) => a.tmId === tm.id)
    );
    if (available) {
      assignTM(slotKey, { id: available.id, name: available.name });
    }
  };

  // ==========================================================================
  // Structured Deployment View — Zones + RR + Aux
  // ==========================================================================

  // ========================================================================
