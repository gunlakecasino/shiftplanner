// ============================================================================

function makeSkeleton(slotKey: string, type: ShiftAssignment["type"], sub?: "mens" | "womens"): ShiftAssignment {
  return {
    slotKey,
    source: null,
    isLocked: false,
    type,
    sub,
  };
