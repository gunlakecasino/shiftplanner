                    <div className="flex items-center gap-1.5">
                      <div className="flex gap-[2px]">
                        <div className="min-w-[18px] h-[15px] px-1 rounded-[4px] bg-[#B91C1C] text-white text-[9px] flex items-center justify-center font-bold tracking-[-0.2px]" style={{ fontFamily: 'var(--font-atkinson)' }}>F</div>
                        <div className="min-w-[18px] h-[15px] px-1 rounded-[4px] bg-[#E5E7EB] text-[#374151] text-[9px] flex items-center justify-center font-medium tracking-[-0.2px]" style={{ fontFamily: 'var(--font-atkinson)' }}>S</div>
                        <div className="min-w-[18px] h-[15px] px-1 rounded-[4px] bg-[#E5E7EB] text-[#374151] text-[9px] flex items-center justify-center font-medium tracking-[-0.2px]" style={{ fontFamily: 'var(--font-atkinson)' }}>S</div>
                        <div className="min-w-[18px] h-[15px] px-1 rounded-[4px] bg-[#E5E7EB] text-[#374151] text-[9px] flex items-center justify-center font-medium tracking-[-0.2px]" style={{ fontFamily: 'var(--font-atkinson)' }}>M</div>
                        <div className="min-w-[18px] h-[15px] px-1 rounded-[4px] bg-[#E5E7EB] text-[#374151] text-[9px] flex items-center justify-center font-medium tracking-[-0.2px]" style={{ fontFamily: 'var(--font-atkinson)' }}>T</div>
                        <div className="min-w-[18px] h-[15px] px-1 rounded-[4px] bg-[#E5E7EB] text-[#374151] text-[9px] flex items-center justify-center font-medium tracking-[-0.2px]" style={{ fontFamily: 'var(--font-atkinson)' }}>W</div>
                        <div className="min-w-[18px] h-[15px] px-1 rounded-[4px] bg-[#E5E7EB] text-[#374151] text-[9px] flex items-center justify-center font-medium tracking-[-0.2px]" style={{ fontFamily: 'var(--font-atkinson)' }}>T</div>
                      </div>
                      {/* Break Group indicators — grey squares with 3 distinct shades.
                          Click any to select the active break group (1/2/3). Defaults to Golden standard. */}
                      <div className="flex gap-[1.5px] pl-1 items-center">
                        {[1, 2, 3].map((g) => {
                          const isActive = breakGroup === g;
                          // Three distinct greys for visual distinction (light → dark)
                          const shade = g === 1 ? '#D1D5DB' : g === 2 ? '#9CA3AF' : '#6B7280';
                          const textColor = g === 3 ? '#FFFFFF' : '#374151';
                          return (
                            <div
                              key={g}
                              onClick={() => setBreakGroup(g as 1 | 2 | 3)}
                              className={`min-w-[13px] h-[13px] px-1 rounded-[2px] text-[8px] flex items-center justify-center font-bold cursor-pointer transition-all ${isActive ? 'ring-1 ring-offset-1 ring-[#111111] border border-[#111111]' : 'border border-transparent'}`}
                              style={{
                                background: shade,
                                color: textColor,
                                fontFamily: 'var(--font-atkinson)',
                              }}
                              title={`Break Group ${g}`}
                            >
                              {g}
                            </div>
                          );
                        })}
                      </div>
                      <div className="text-[8.5px] text-[#555] ml-0.5 tracking-[0.8px] font-medium" style={{ fontFamily: 'var(--font-atkinson)' }}>GROUPS</div>
                    </div>

                {/* ==================================================================== */}
                {/* VIEW-SWITCHED CONTENT (Deployment vs Breaks & Overlaps) */}
                {/* ==================================================================== */}
                {currentView === "deployment" ? (
                  <>
                    {/* ZONES SECTION — 2×5 grid of colored rectangular cards */}
                    <div>
                      <div className="sheet-section-header">
                        <span className="label">ZONES</span>
                        <span className="divider" />
                        <span className="count">
                          {ZONE_DEFS.filter(d => !!assignments[d.key]?.tmName).length} / 10 FILLED
                        </span>
                      </div>

                      <div className="grid grid-cols-5 gap-[7px]">
                        {ZONE_DEFS.map((def) => renderZoneCard(def))}
                      </div>
                    </div>
                <div>
                  <div className="sheet-section-header">
                    <span className="label">ZONES</span>
                    <span className="divider" />
                    <span className="count">
                      {ZONE_DEFS.filter(d => !!assignments[d.key]?.tmName).length} / 10 FILLED
                    </span>
                  </div>

                  <div className="grid grid-cols-5 gap-[7px]">
                    {ZONE_DEFS.map((def) => renderZoneCard(def))}
                  </div>
                </div>

                {/* RESTROOMS SECTION — 5 paired cards with M/W columns */}
                <div className="mt-2.5">
                  <div className="sheet-section-header">
                    <span className="label">RESTROOMS</span>
                    <span className="divider" />
                    <span className="count">
                      {RR_DEFS.reduce((acc, d) => {
                        const m = !!assignments[`MRR${d.num}`]?.tmName;
                        const w = !!assignments[`WRR${d.num}`]?.tmName;
                        return acc + (m ? 1 : 0) + (w ? 1 : 0);
                      }, 0)} / 10 FILLED
                    </span>
                  </div>

                  <div className="grid grid-cols-5 gap-[7px]">
                    {RR_DEFS.map((def) => renderRRCard(def))}
                  </div>
                </div>
                </>
                ) : (
                  /* ===================================================== */
                  /* BREAKS & OVERLAPS VIEW — Golden Break Sheet style   */
                  /* ===================================================== */
                  <div className="break-sheet">
                    {/* Break Sheet masthead — closer to golden (top day-color bar, "Break Sheet", IN ROTATION, "By Break Wave", week dots + groups) */}
                    <div className="mb-2 -mx-1 px-1 pt-1" style={{ borderTop: `6px solid ${selectedDay.color}` }}>
                      <div className="flex items-end justify-between">
                        <div>
                          <div className="text-[10px] font-bold tracking-[1.5px] text-[#3C3C43]">BREAK SHEET</div>
                          <div className="text-[20px] font-semibold tracking-[-0.4px]" style={{ color: selectedDay.color }}>
                            {selectedDay.name} · {selectedDay.meta.split('·')[0].trim()}
                          </div>
                          <div className="flex items-center gap-2 mt-0.5">
                            <span className="text-[11px] font-bold text-[#111]">23</span>
                            <span className="text-[9.5px] tracking-[0.1em] uppercase text-[#6B7280]">In Rotation</span>
                          </div>
                        </div>

                        <div className="flex flex-col items-end gap-1">
                          <div className="text-[9px] font-semibold tracking-wider text-[#3C3C43]">By Break Wave</div>

                          {/* Week pills + GROUP dots inside the sheet, golden style */}
                          <div className="flex items-center gap-1.5">
                            <div className="flex gap-[1px]">
                              {DAY_DEFS.map((d, i) => (
                                <div
                                  key={i}
                                  className={`min-w-[18px] h-[18px] text-[9px] flex items-center justify-center font-bold rounded ${i === selectedDayIndex ? 'text-white' : 'text-[#6B7280]'}`}
                                  style={{ background: i === selectedDayIndex ? selectedDay.color : '#E5E7EB' }}
                                >
                                  {d.short}
                                </div>
                              ))}
                            </div>
                            <div className="text-[8px] text-[#6B7280] ml-0.5">GROUP</div>
                            <div className="flex gap-px">
                              {[1,2,3].map(g => (
                                <div key={g} className="w-[14px] h-[14px] rounded text-[8px] flex items-center justify-center font-bold text-white" style={{ background: g===1 ? '#1a2332' : g===2 ? '#5a6b7d' : '#c8d3dc' }}>{g}</div>
                              ))}
                            </div>
                          </div>
                        </div>
                      </div>
                    </div>

                    {/* Break columns — matching golden exactly: 3 cols, giant wave num, "Break N" + count, section dividers, rows with left accent, who-line (name + locations), right badge */}
                    <div className="grid grid-cols-3 gap-3">
                      {[1,2,3].map(wave => {
                        const waveAssignments = Object.values(assignments).filter(a => a.breakGroup === wave);
                        const count = waveAssignments.length;
                        const waveColor = wave === 1 ? '#1a2332' : wave === 2 ? '#5a6b7d' : '#c8d3dc';

                        const getLocs = (a: any) => {
                          if (a.type === 'zone') return ZONE_DEFS.find(z => z.key === a.slotKey)?.locations?.join(' · ') || '';
                          if (a.type === 'rr') {
                            const num = parseInt(a.slotKey.replace(/\D/g, '')) || 1;
                            const def = RR_DEFS.find(r => r.num === num);
                            return def ? `${def.mensLoc} / ${def.womensLoc}` : '';
                          }
                          return '';
                        };

                        return (
                          <div key={wave} className="border border-[#E5E5E7] rounded bg-white overflow-hidden flex flex-col" style={{ borderTop: `3px solid ${waveColor}` }}>
                            {/* Col head like golden */}
                            <div className="p-2 flex items-end gap-3" style={{ color: waveColor }}>
                              <div className="text-[52px] font-extrabold tabular-nums leading-none tracking-[-1px]">{wave}</div>
                              <div className="-mb-1">
                                <div className="text-[11px] font-semibold tracking-[0.08em] uppercase">Break {wave}</div>
                                <div className="text-[10px] text-[#6B7280]">{count} people</div>
                              </div>
                            </div>

                            <div className="px-2 pb-2 flex-1 space-y-1.5 text-[9.5px]">
                              {['zone','rr','aux'].map(cat => {
                                const items = waveAssignments.filter(a => a.type === cat);
                                if (!items.length) return null;
                                const label = cat === 'zone' ? 'Zones' : cat === 'rr' ? 'Restrooms' : 'Auxiliary';
                                return (
                                  <div key={cat}>
                                    {/* Section divider like golden */}
                                    <div className="text-[#9CA3AF] font-semibold tracking-[0.14em] uppercase text-[8px] mb-0.5 flex items-center gap-1">
                                      {label}
                                      <div className="flex-1 h-px bg-[#E5E7EB]" />
                                    </div>
                                    {items.map(a => (
                                      <div key={a.slotKey} className="flex items-start gap-1.5 py-0.5 border-b border-[#F3F4F6] last:border-0">
                                        <div className="flex-1 min-w-0">
                                          <div className="font-semibold text-[#111] truncate">{a.tmName || '—'}</div>
                                          <div className="text-[#6B7280] text-[8px] leading-tight truncate">{getLocs(a)}</div>
                                        </div>
                                        <div className="text-[8px] font-medium px-1 py-0.5 rounded whitespace-nowrap" style={{ background: waveColor, color: '#fff' }}>
                                          {a.slotKey}
                                        </div>
                                      </div>
                                    ))}
                                  </div>
                                );
                              })}
                            </div>
                          </div>
                        );
                      })}
                    </div>

                    {/* Overlaps section — golden style with time windows + 6 mini slots each */}
                    <div className="mt-3 border-t pt-2">
                      <div className="flex items-center justify-between mb-1.5">
                        <span className="font-semibold tracking-wider text-[10.5px]">OVERLAPS</span>
                        <span className="text-[9.5px] text-[#6B7280]">0 / 12 FILLED</span>
                      </div>

                      <div className="grid grid-cols-2 gap-3">
                        {/* PM */}
                        <div>
                          <div className="text-[11px] font-semibold text-[#111]">11p – 1a</div>
                          <div className="text-[8.5px] text-[#6B7280] -mt-0.5">Late evening</div>
                          <div className="grid grid-cols-6 gap-1 mt-1">
                            {Array.from({length:6}).map((_,i) => (
                              <div key={i} className="border border-[#E5E5E7] rounded p-1 text-[8px] min-h-[26px] flex items-center justify-center text-[#9CA3AF]">
                                —
                              </div>
                            ))}
                          </div>
                        </div>

                        {/* AM */}
                        <div>
                          <div className="text-[11px] font-semibold text-[#111]">5a – 7a</div>
                          <div className="text-[8.5px] text-[#6B7280] -mt-0.5">Early morning</div>
                          <div className="grid grid-cols-6 gap-1 mt-1">
                            {Array.from({length:6}).map((_,i) => (
                              <div key={i} className="border border-[#E5E5E7] rounded p-1 text-[8px] min-h-[26px] flex items-center justify-center text-[#9CA3AF]">
                                —
                              </div>
                            ))}
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>
                )}

                {/* Sheet footer — context-aware (Golden style) */}
                <div className="sheet-footer">
                  <div>GLCR • GRAVE SHIFT DEPLOYMENT</div>
                  <div>{selectedDay.name} {selectedDay.meta} • {currentView === "deployment" ? "Zone Deployment Sheet" : "Break Sheet"} • Editable</div>
                  <div>OMS v1</div>
                </div>
              </div>
              {/* End of print-sheet content inside the artboard */}
            </div>

            {/* Caption now properly below the artboard (stacked in the column wrapper) */}
            <div className="mt-3 text-center text-[9px] text-[#8E8E93] tracking-wider">
              Letter Landscape (11 × 8.5 in) • Exact print proportions • Drag from roster or tap cards to assign
            </div>

            {/* QuickActionQuickLook — contextual fan that expands around the clicked card */}
            {quickActionFor && quickLookPosition && (() => {
              const currentAssignment = assignments[quickActionFor] || {};
              const hasTM = !!currentAssignment.tmName;
              const currentBreak = currentAssignment.breakGroup ?? 1;
              const isBreakFanOpen = breakFanOpenFor === quickActionFor;

              const { x, y, width = 110 } = quickLookPosition;

              // 5 actions — fan expands off the right edge of the clicked element (zone card, RR gender section, or aux)
              const actions = [
                { key: 'assign', icon: Icons.plus, color: '#0A84FF', action: () => { /* TODO: roster picker */ setQuickActionFor(null); setQuickLookPosition(null); } },
                { key: 'remove', icon: Icons.trash, color: '#B91C1C', show: hasTM, action: () => { unassign(quickActionFor); setQuickActionFor(null); setQuickLookPosition(null); } },
                { key: 'lock', icon: currentAssignment.isLocked ? Icons.unlock : Icons.lock, color: '#374151', action: () => { toggleLock(quickActionFor); setQuickActionFor(null); setQuickLookPosition(null); } },
                { key: 'tasks', icon: Icons.edit, color: '#374151', action: () => { /* TODO: task editor */ setQuickActionFor(null); setQuickLookPosition(null); } },
                { key: 'break', isBreak: true, action: () => {} }, // the three grey pills live here
              ].filter(a => a.show !== false);

              return (
                <div
                  className="absolute z-[95] pointer-events-none"
                  style={{ left: 0, top: 0, width: '100%', height: '100%' }}
                  onClick={() => { setQuickActionFor(null); setQuickLookPosition(null); }}
                >
                  <div
                    className="absolute pointer-events-auto"
                    style={{
                      left: x + width + 2, // nudged 2px outside the right border to match the exact red circle position in the annotation
                      top: y,
                      transform: 'translate(0%, -50%)',
                    }}
                    onClick={e => e.stopPropagation()}
                  >
                    {/* Hub dot — center placed exactly on the right border of the tapped card (as indicated by red circle) */}
                    <div className="absolute left-0 -translate-x-1/2 top-1/2 -translate-y-1/2 w-3.5 h-3.5 rounded-full bg-white border border-[#C8C8CC] shadow z-10" />

                    {/* The 5 fanned items */}
                    {actions.map((item, i) => {
                      const total = actions.length;
                      // Rightward fan off the right edge of the card
                      // Primarily to the right, with a gentle downward arc ("right corner down")
                      const startAngle = -55;
                      const endAngle = 25;
                      const angle = startAngle + (i * (endAngle - startAngle) / (total - 1));
                      const distance = 68; // a bit more breathing room between the five larger icons on the right-edge fan

                      return (
                        <div
                          key={item.key}
                          className="absolute"
                          style={{
                            left: 0, // radiate from the attachment point (left of this container = right edge of card)
                            top: '50%',
                            transform: `rotate(${angle}deg) translate(${distance}px) rotate(${-angle}deg)`,
                          }}
                        >
                          {item.isBreak ? (
                            isBreakFanOpen ? (
                              // Expanded break blade — the three grey pills fan out from this position
                              <div className="flex gap-0.5">
                                {[1,2,3].map(g => {
                                  const shades = {1: '#E5E7EB', 2: '#9CA3AF', 3: '#6B7280'};
                                  const active = currentBreak === g;
                                  return (
                                    <div
                                      key={g}
                                      onClick={(e) => {
                                        e.stopPropagation();
                                        setBreakGroupForSlot(quickActionFor, g as 1|2|3);
                                        setQuickActionFor(null);
                                        setQuickLookPosition(null);
                                        setBreakFanOpenFor(null);
                                      }}
                                      className={`w-[13px] h-[13px] flex items-center justify-center text-[7px] font-bold rounded-[2px] border cursor-pointer transition-all ${active ? 'border-[#111] scale-110' : 'border-[#D1D5DB] hover:scale-105'}`}
                                      style={{ background: shades[g], color: g===3 ? '#fff' : '#374151', fontFamily: 'var(--font-atkinson)', boxShadow: '0 1px 2px rgba(0,0,0,0.1)' }}
                                      title={`Break Group ${g}`}
                                    >
                                      {g}
                                    </div>
                                  );
                                })}
                              </div>
                            ) : (
                              // Collapsed break blade — single icon, click to expand
                              <button
                                onClick={(e) => {
                                  e.stopPropagation();
                                  setBreakFanOpenFor(quickActionFor);
                                }}
                                onMouseEnter={() => {
                                  clearTimeout(fanHoverTimer);
                                  const t = setTimeout(() => setFanHoveredItem(item.key), 1200);
                                  setFanHoverTimer(t);
                                }}
                                onMouseLeave={() => {
                                  clearTimeout(fanHoverTimer);
                                  setFanHoveredItem(null);
                                }}
                                className="w-6 h-6 rounded-full bg-white border border-[#E5E5E7] flex items-center justify-center shadow-sm hover:shadow-md active:scale-95 transition-all"
                                style={{ color: item.color, boxShadow: '0 2px 5px rgba(0,0,0,0.13)' }}
                                title="Break Group"
                              >
                                <Icon size={13}>{Icons.users}</Icon>
                              </button>
                            )
                          ) : (
                            <button
                              onClick={(e) => { e.stopPropagation(); item.action(); }}
                              className="w-9 h-9 rounded-full bg-white border border-[#E5E5E7] flex items-center justify-center shadow-md hover:shadow-lg active:scale-95 transition-all"
                              style={{ color: item.color, boxShadow: '0 3px 8px rgba(0,0,0,0.16)' }}
                              title={item.key}
                            >
                              <Icon size={18}>{item.icon}</Icon>
                            </button>
                          )}
                        </div>
                      );
                    })}
                  </div>
                </div>
              );
            })()}
          </div>
        </div>
      </div>

      {/* ==================================================================== */}
      {/* Bottom Status Bar — calm, authoritative */}
      {/* ==================================================================== */}
      <div className="h-11 border-t border-[#E5E5E7] bg-white/70 backdrop-blur flex items-center px-6 text-xs text-[#8E8E93]">
        <div className="flex-1">Draft • Last saved moments ago</div>
        <div>Engine ready • 3 manual overrides</div>
      </div>
    </div>
  );
}
